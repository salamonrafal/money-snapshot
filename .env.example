DB_URL=jdbc:postgresql://postgres:5432/money_snapshot
APP_DB_NAME=money_snapshot
DB_USERNAME=money_snapshot
DB_PASSWORD=<set_application_database_password>
SERVER_PORT=5081
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<set_postgres_admin_password>
# Generate a long random secret for remember-me signing before running the app.
REMEMBER_ME_KEY=<generate_a_long_random_secret>
# Optional remember-me cookie lifetime in days. Default: 30
REMEMBER_ME_DAYS=30
